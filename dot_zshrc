# Enable Powerlevel10k instant prompt. Keep near the top of ~/.zshrc.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Paths and environment
export ZSH="$HOME/.oh-my-zsh"
export EDITOR="nvim"
export MYVIMRC="$HOME/.config/nvim/init.lua"
export MYZSHRC="$HOME/.zshrc"
export MYKITTYRC="$HOME/.config/kitty/kitty.conf"
export NVP="$HOME/.config/nvim/lua/plugins/"
export MYYAZIRC="$HOME/.config/yazi/themes.toml"

# User-local binaries
export PATH="$HOME/.local/bin:$PATH"

# Platform-specific setup
case "$OSTYPE" in
  darwin*)
    # Homebrew on Apple Silicon or Intel macOS
    if [[ -x /opt/homebrew/bin/brew ]]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -x /usr/local/bin/brew ]]; then
      eval "$(/usr/local/bin/brew shellenv)"
    fi
    ;;
  linux*)
    # Nothing special needed here right now
    ;;
esac

# Oh My Zsh theme
ZSH_THEME="powerlevel10k/powerlevel10k"

# Plugins chosen by OS
plugins=(git zoxide sudo colored-man-pages command-not-found)

case "$OSTYPE" in
  darwin*)
    plugins+=(macos brew)
    ;;
  linux*)
    # Debian/Linux-specific plugin additions can go here later
    ;;
esac

# Load Oh My Zsh only if installed
if [[ -f "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
fi

# Aliases
alias nv='nvim'
alias zshconfig='chezmoi edit ~/.zshrc'
alias vimconfig='chezmoi edit ~/.config/nvim/init.lua'
alias kittyconfig='chezmoi edit ~/.config/kitty/kitty.conf'
alias reload='chezmoi apply && source ~/.zshrc'
alias unmountix='umount ~/.sshfs/ixdev'
alias chedit='chezmoi edit'
alias cat='bat'
alias ls='eza --icons --group-directories-first'
alias ll='eza -lah --icons --group-directories-first --git'
alias tree='eza --tree --icons'
alias ff='fastfetch'
alias cd='z'
alias j='z'
alias jj='zi'
alias f='open .'
alias myip='curl ifconfig.me'
alias ports='lsof -iTCP -sTCP:LISTEN -n -P'
alias wdcp='pwd | pbcopy'

# Git Aliases
alias ga='git add'
alias gs='git status'
alias gaa='git add .'
alias gcm='git commit -m'
alias gp='git push'
alias gu='git pull'

# Brew Aliases
alias bi='brew install'

# Opts
setopt autocd
setopt interactivecomments
setopt histignorealldups
setopt sharehistory

# History
HISTSIZE=10000
SAVEHIST=10000
HISTFILE="$HOME/.zsh_history"

# Functions
function y() {
  local tmp cwd
  tmp="$(mktemp -t yazi-cwd.XXXXXX)" || return

  command yazi "$@" --cwd-file="$tmp"
  IFS= read -r -d '' cwd < "$tmp"

  if [[ -n "$cwd" && "$cwd" != "$PWD" && -d "$cwd" ]]; then
    builtin cd -- "$cwd"
  fi

  rm -f -- "$tmp"
}

# Prompt
[[ -f "$HOME/.p10k.zsh" ]] && source "$HOME/.p10k.zsh"

# zoxide
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi
